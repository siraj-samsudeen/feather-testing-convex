{
  "name": "feather-testing-convex",
  "version": "0.5.3",
  "description": "React provider that adapts convex-test's one-shot client for use with ConvexProvider, so useQuery/useMutation work in tests.",
  "license": "MIT",
  "keywords": [
    "convex",
    "testing",
    "react",
    "provider",
    "convex-test"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siraj-samsudeen/feather-testing-convex.git"
  },
  "bugs": {
    "url": "https://github.com/siraj-samsudeen/feather-testing-convex/issues"
  },
  "homepage": "https://github.com/siraj-samsudeen/feather-testing-convex#readme",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vitest-plugin": {
      "types": "./dist/vitest-plugin.d.ts",
      "import": "./dist/vitest-plugin.js",
      "default": "./dist/vitest-plugin.js"
    },
    "./playwright": {
      "types": "./dist/playwright/index.d.ts",
      "import": "./dist/playwright/index.js",
      "default": "./dist/playwright/index.js"
    },
    "./rtl": {
      "types": "./dist/rtl/index.d.ts",
      "import": "./dist/rtl/index.js",
      "default": "./dist/rtl/index.js"
    },
    "./tanstack-query": {
      "types": "./dist/tanstack-query.d.ts",
      "import": "./dist/tanstack-query.js",
      "default": "./dist/tanstack-query.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@convex-dev/auth": ">=0.0.80",
    "@convex-dev/react-query": ">=0.1.0",
    "@playwright/test": ">=1.40.0",
    "@tanstack/react-query": ">=5.0.0",
    "@testing-library/react": ">=14.0.0",
    "@testing-library/user-event": ">=14.0.0",
    "convex": ">=1.0.0",
    "convex-test": ">=0.0.1",
    "react": ">=18.0.0",
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@convex-dev/auth": {
      "optional": true
    },
    "@convex-dev/react-query": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "@testing-library/user-event": {
      "optional": true
    }
  },
  "dependencies": {
    "feather-testing-core": "^0.1.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/react-query": "^0.1.0",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.10",
    "@vitejs/plugin-react": "^5.1.3",
    "convex": "^1.31.7",
    "convex-test": "^0.0.41",
    "jsdom": "^28.0.0",
    "react": "^19.2.4",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
